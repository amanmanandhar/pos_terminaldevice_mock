<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="terminal_device_view_list" model="ir.ui.view">
        <field name="name">terminal.device.view.list</field>
        <field name="model">terminal.device</field>
        <field name="arch" type="xml">
            <list string="Terminal List">
                <field name="name"/>
                <field name="ip_address"/>
                <field name="port"/>
                <field name="api_key"/>
                <field name="active"/>
                <field name="status"/>
            </list>
        </field>
    </record>
    <record id="terminal_device_view_form" model="ir.ui.view">
        <field name="name">terminal.device.view.form</field>
        <field name="model">terminal.device</field>
        <field name="arch" type="xml">
            <form string="Terminal device form">
            <header>
                <button name="action_test_connection" class="btn btn-primary" string="Test Connection" type="object"/>
                <field name="status" widget="statusbar" statusbar_visible="online,offline,error"/>
            </header>
                <sheet>
                    <group string="Device Information">
                        <field name="name"/>
                        <field name="ip_address"/>
                        <field name="port"/>
                    </group>
                    <group string="Device Connections">
                        <field name="api_key"/>
                        <field name="active"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="terminal_device_action" model="ir.actions.act_window">
        <field name="name">Terminal Device</field>
        <field name="res_model">terminal.device</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first record
            </p>
        </field>
    </record>
    <menuitem id="terminal_device_root" name="Terminal Device" sequence="35"/>
    <menuitem id="terminal_device_menu" name="Add device" parent="terminal_device_root" action="terminal_device_action" sequence="26"/>

</odoo>